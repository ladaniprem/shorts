NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/new
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/new

# Connect to Supabase via connection pooling
DATABASE_URL=""
# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://"

// Gemini API key for accessing Gemini services for generating script 
GEMINI_API_KEY=

# SiliconFlow API key — FLUX.1 image generation (best quality, free $1 signup credit)
# Get your free key at: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=

// Replicate API token for accessing Replicate services for generating images
# REPLICATE_API_TOKEN=

# HF_TOKEN=

// AWS S3 configuration for storing files
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ElevenLabs API key — TTS fallback when Gemini quota is exhausted (free: 10k chars/month)
ELEVENLABS_API_KEY=

// AssemblyAI API key for transcription services
ASSEMBLY_API_KEY=

REMOTION_AWS_ACCESS_KEY_ID=
REMOTION_AWS_SECRET_ACCESS_KEY=

# Groq API key — fallback for script generation when Gemini quota is exhausted
# Get your free key at: https://console.groq.com
GROQ_API_KEY=
SAMBANOVA_API_KEY=
OPENROUTER_API_KEY=

RAZORPAY_KEY_ID=
